# --- App ---
PORT=
NODE_ENV=

# --- Ethereum / Alchemy ---
# WSS endpoint lazım (event subscription için). HTTPS değil!
# Format: wss://eth-mainnet.g.alchemy.com/v2/<KEY>
ETH_WSS_URL=

# --- USDT contract (mainnet) ---
USDT_CONTRACT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7
USDT_DECIMALS=6

# --- Filter ---
# Bu USDT cinsinden (insan-okur). 100k = 100000.
MIN_TRANSFER_USDT=100000

# --- Firebase Admin (Aşama 5'te dolduracaksın) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- FCM ---
FCM_TOPIC=usdt-large-transfers
